{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/main.tsx"],
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignore": ["android/**", "ios/**"],
  "ignoreFiles": ["src/leaflet-shim.d.ts"],
  "ignoreDependencies": [
    "@capacitor/android",
    "@capacitor/ios",
    "@supabase/postgrest-js",
    "hermes-parser",
    "iceberg-js",
    "magic-string",
    "tslib",
    "@rollup/wasm-node"
  ],
  "ignoreBinaries": ["powershell"]
}
