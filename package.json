{
  "name": "videocanvass-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ensure-deps": "node scripts/ensure-deps.mjs",
    "postinstall": "node scripts/rollup-wasm-win32-fallback.mjs",
    "startdev": "node scripts/ensure-deps.mjs && vite --host 0.0.0.0 --port 5173",
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "build": "node scripts/ensure-deps.mjs && node ./node_modules/typescript/lib/tsc.js -b && node ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "knip": "knip",
    "depcheck": "depcheck",
    "preview": "vite preview",
    "cap:sync": "npm run build && node scripts/cap-copy-web.cjs",
    "cap:sync:cli": "npm run build && npx cap sync",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "verify:ios-git": "node scripts/verify-ios-git.cjs",
    "appetize:android": "powershell -ExecutionPolicy Bypass -File scripts/build-android-appetize.ps1",
    "appetize:ios": "bash scripts/build-ios-simulator-appetize.sh",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@supabase/postgrest-js": "^2.102.1",
    "@supabase/supabase-js": "^2.102.1",
    "hermes-parser": "^0.34.0",
    "iceberg-js": "^0.8.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "localforage": "^1.10.0",
    "magic-string": "^0.30.21",
    "maplibre-gl": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@rollup/wasm-node": "^4.60.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "knip": "^6.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
