{
  "name": "videocanvass-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ensure-deps": "node scripts/ensure-deps.mjs",
    "startdev": "node scripts/ensure-deps.mjs && vite --host 0.0.0.0 --port 5173",
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "knip": "knip",
    "depcheck": "depcheck",
    "preview": "vite preview",
    "cap:sync": "npm run build && node scripts/cap-copy-web.cjs",
    "cap:sync:cli": "npm run build && npx cap sync",
    "cap:open": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "appetize:android": "powershell -ExecutionPolicy Bypass -File scripts/build-android-appetize.ps1",
    "appetize:ios": "bash scripts/build-ios-simulator-appetize.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@supabase/supabase-js": "^2.57.4",
    "leaflet": "^1.9.4",
    "localforage": "^1.10.0",
    "maplibre-gl": "^5.21.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "knip": "^6.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
