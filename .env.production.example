# Copy to `.env.production` in the repo root before `npm run build` for Capacitor (iOS/Android).
# Vercel env vars do NOT apply to builds you run locally — mirror production here.
# See docs/XCODE_BUILD.md and docs/MOBILE_RELEASE.md section 1.1.

# Required in native WebView: same HTTPS origin as deployed web (no path, no trailing slash).
VITE_APP_SERVER_ORIGIN=https://www.example.com

# Password reset redirect in Capacitor; often same as VITE_APP_SERVER_ORIGIN.
# VITE_VC_SITE_URL=https://www.example.com

# Required: same Supabase project as production (see .env.example).
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# VITE_VC_RELATIONAL_BACKEND=true
