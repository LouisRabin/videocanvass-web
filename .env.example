# Copy this file to `.env.local` and fill in values from Supabase → Project Settings → API.
# Restart `npm run dev` after any change (Vite reads env only at startup).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Public client key (RLS enforced). Supabase UI may label this as:
# - "Publishable" key (sb_publishable_...), or
# - Legacy tab → "anon public" (JWT eyJ...). Do NOT use service_role / secret keys here.
VITE_SUPABASE_ANON_KEY=your_publishable_or_legacy_anon_key_here

# Relational Postgres + email login (vc_cases, etc.). Values: true / false / 1 / 0 / yes / no (see backendMode.ts).
# In `npm run dev`, omit or set false to use mock “demo sign-in” unless you need Supabase locally.
# In production builds, if this is omitted or blank but URL+anon key are set, relational mode defaults ON (Vercel-friendly).
VITE_VC_RELATIONAL_BACKEND=true

# Optional: show build/debug strip (Supabase host + relational flag) and extra vc_cases upsert logs.
# VITE_VC_DEBUG=true

# Legacy blob sync only (when relational is false). Same value on every client.
# VITE_SHARED_WORKSPACE_ID=demo-workspace

# Optional: public site URL with scheme (https://...) for password-reset emails if redirect must be fixed.
# VITE_VC_SITE_URL=https://your-app.vercel.app

# Local Supabase only: Resend API key when [auth.email.smtp] is enabled in supabase/config.toml (see docs/RESEND_CAMERACANVASS.md).
# RESEND_API_KEY=re_...

# --- Vercel ---
# Set the three VITE_* variables above for BOTH Production and Preview so videocanvass-web.vercel.app
# matches preview deployments. See docs/DEPLOY_SUPABASE_VERCEL.md.
# If you use the Vercel ↔ Supabase integration (locked `SUPABASE_URL` / `SUPABASE_ANON_KEY`), the build still
# picks those up via vite.config.ts fallbacks — no duplicate `VITE_*` copy required when both are present.
