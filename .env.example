# Copy to .env.local for Vite (never commit secrets).
#
# IMPORTANT — Web + Android (Capacitor): the same variables are baked into dist/ at `npm run build`.
# Use the same Supabase project and values for your hosted web deploy and for every Play Store AAB
# so cloud data and auth match across browser and app. A build without URL/key falls back to local-only.

# Supabase (optional — without these, the app uses local IndexedDB only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Legacy shared JSON workspace (single blob `vc_app_state`). Same value on every build that should share
# that dataset (e.g. nypd-poc). Ignored when relational backend is on.
VITE_SHARED_WORKSPACE_ID=demo-workspace

# Set to "true" to use Postgres tables + Row Level Security + Supabase Auth instead of vc_app_state.
# Requires applying SQL in supabase/migrations/ and configuring Supabase Auth + Storage.
# When true: email/password sign-in, optional TOTP MFA (Cases → Security / 2FA), no mock user picker.
VITE_VC_RELATIONAL_BACKEND=false
