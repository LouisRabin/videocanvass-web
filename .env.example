# Copy to .env.local for Vite (never commit secrets).

# Supabase (optional — without these, the app uses local IndexedDB only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Legacy shared JSON workspace (single blob `vc_app_state`). Do not use in production multi-user.
VITE_SHARED_WORKSPACE_ID=demo-workspace

# Set to "true" to use Postgres tables + Row Level Security + Auth instead of vc_app_state.
# Requires applying SQL in supabase/migrations/ and configuring Supabase Auth + Storage.
VITE_VC_RELATIONAL_BACKEND=false
